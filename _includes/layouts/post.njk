---
layout: base
title: Evento — Rastrexando
---

<nav class="breadcrumbs">
  <ul>
    <li>{% renderHTMXLink "/", "Inicio", "link" %}</li>
    <li class="breadcrumb-sep">›</li>
    <li>{% renderHTMXLink "/calendarios/", "Calendarios", "link" %}</li>
    <li class="breadcrumb-sep">›</li>
    <li>{% renderHTMXLink "/calendarios/" + date.getFullYear() + "/", date.getFullYear(), "link" %}</li>
    <li class="breadcrumb-sep">›</li>
    <li class="is-light-blue">{{ date | toGLMonthDay }}</li>
  </ul>
</nav>

{% if image %}
  <a class="event-hero-link" href="/recursos/imaxes/{{ image }}" title="{{ title }}" target="_blank">
    <img class="event-hero" src="/recursos/imaxes/{{ image }}" alt="{{ title }}" />
    <span class="hero-expand-hint"><i class="fi-arrows-expand"></i></span>
  </a>
{% endif %}

<div class="page page-post">

  <div class="event-type-row">
    {% if tags %}
      {% if "andaina" in tags %}
        <span class="type-pill andaina">Andaina</span>
      {% else %}
        <span class="type-pill rastrexo">Rastrexo</span>
      {% endif %}
    {% endif %}
    {% set relDate = date | toRelativeDate %}
    {% if relDate %}
      <span class="relative-date">{{ relDate }}</span>
    {% endif %}
  </div>

  <h1>{{ title }}</h1>

  <div class="event-info">
    <div class="event-info-item">
      <i class="fi-calendar is-light-blue"></i>
      <span>{{ date | toGlLocale }}</span>
    </div>
    <div class="event-info-item">
      <i class="fi-marker is-light-blue"></i>
      <span>{{ location }}</span>
    </div>
    {% if source_url %}
    <div class="event-info-item">
      <i class="fi-social-facebook is-light-blue"></i>
      <a href="{{ source_url }}" title="{{ source_name }}" target="_blank">{{ source_name }}</a>
    </div>
    {% elif source_name %}
    <div class="event-info-item">
      <i class="fi-home is-light-blue"></i>
      <span>{{ source_name }}</span>
    </div>
    {% endif %}
  </div>

  {% if videos %}
    <section class="video-section">
      <h2>Vídeos</h2>
      <div class="video-list">
        {% for video in videos %}
          <iframe width="100%" height="315" src="https://www.youtube.com/embed/{{ video.id }}" title="{{ video.title }}" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" referrerpolicy="strict-origin-when-cross-origin" allowfullscreen></iframe>
        {% endfor %}
      </div>
    </section>
  {% endif %}

  {{ content | safe }}

  <div class="prev-next-buttons">
    {% set previousPost = collections.post | getPreviousCollectionItem(page) %}
    {% set nextPost = collections.post | getNextCollectionItem(page) %}
    {% if previousPost %}
      {% renderHTMXLink previousPost.url, "← Anterior" %}
    {% else %}
      <div class='not-allowed'>← Anterior</div>
    {% endif %}
    {% if nextPost %}
      {% renderHTMXLink nextPost.url, "Seguinte →" %}
    {% else %}
      <div class='not-allowed'>Seguinte →</div>
    {% endif %}
  </div>

</div>

<script type="application/ld+json">
{
  "name": "{{ title }}",
  "startDate": "{{ date | dateOnly }}",
  "url": "{{ page.url }}",
  "eventAttendanceMode": "https://schema.org/OfflineEventAttendanceMode",
  "description": "",
  {% if image %}
  "image": "/recursos/imaxes/{{ image }}",
  {% else %}
  "image": null,
  {% endif %}
  "@context": "http://schema.org",
  "@type": "Event",
  "eventStatus": "EventScheduled",
  "location": {
    "@type": "Place",
    "name": "{{ location }}"
  },
  "organizer": { "@type": "Organization", "name": "{{ source_name }}", "url": "{{ source_url }}" }
}
</script>
