---
title: Rastrexando
---

<!doctype html>
<html lang="gl">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap">
		<link rel="stylesheet" href="/recursos/foundation-icons/foundation-icons.css" />
		<link rel="stylesheet" href="/recursos/bundle.css">
    <title>{{ title }}</title>

		<!-- Meta -->
		<meta name="author" content="Carlos González Goce">
    <meta name="keywords" content="rastrexo,rastrexar,rastrexando,andaina,galicia"/>

    {%- set _siteDesc = "Rastrexando — A túa plataforma de referencia para non perderte ningún Rastrexo" -%}
    {%- set _desc = description if description else _siteDesc -%}
    {%- set _baseUrl = "https://www.rastrexando.eu" -%}
    {%- set _ogImage = (_baseUrl + "/recursos/imaxes/" + image) if image else (_baseUrl + "/recursos/landing.jpg") -%}

    <meta name="description" content="{{ _desc }}">

    <!-- Open Graph -->
    <meta property="og:site_name" content="Rastrexando">
    <meta property="og:locale" content="gl_ES">
    <meta property="og:type" content="{{ 'article' if image else 'website' }}">
    <meta property="og:title" content="{{ title }}">
    <meta property="og:description" content="{{ _desc }}">
    <meta property="og:url" content="{{ _baseUrl }}{{ page.url }}">
    <meta property="og:image" content="{{ _ogImage }}">
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{{ title }}">
    <meta name="twitter:description" content="{{ _desc }}">
    <meta name="twitter:image" content="{{ _ogImage }}">

		<!-- Favicon (made with http://realfavicongenerator.net/) -->
    <link rel="apple-touch-icon" sizes="180x180" href="/recursos/apple-touch-icon.png?v2=Gvk3Pm9dNO">
    <link rel="icon" type="image/png" sizes="32x32" href="/recursos/favicon-32x32.png?v2=Gvk3Pm9dNO">
    <link rel="icon" type="image/png" sizes="16x16" href="/recursos/favicon-16x16.png?v2=Gvk3Pm9dNO">
    <link rel="manifest" href="/recursos/site.webmanifest?v2=Gvk3Pm9dNO">
    <link rel="mask-icon" href="/recursos/safari-pinned-tab.svg?v2=Gvk3Pm9dNO" color="#5bbad5">
    <link rel="shortcut icon" href="/recursos/favicon.ico?v2=Gvk3Pm9dNO">
    <meta name="apple-mobile-web-app-title" content="Rastrexando">
    <meta name="application-name" content="Rastrexando">
    <meta name="msapplication-TileColor" content="#da532c">
    <meta name="theme-color" content="#ffffff">

    <!-- Scripts -->
    <script src="/recursos/js/htmx.min.js"></script>

    <!-- Structured data -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "WebSite",
      "url": "https://www.rastrexando.eu",
      "name": "Rastrexando",
      "description": "A túa plataforma de referencia para non perderte ningún Rastrexo"
    }
    </script>
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Rastrexando",
      "url": "https://www.rastrexando.eu",
      "logo": "https://www.rastrexando.eu/recursos/rastrexando-simbolo.png",
      "foundingDate": "2017",
      "founders": [
        {
          "@type": "Person",
          "name": "Carlos González Goce",
          "sameAs": ["https://www.linkedin.com/in/carlos-goce/"]
        }
      ],
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Baiona",
        "addressRegion": "Pontevedra",
        "addressCountry": "ES"
      },
      "contactPoint": {
        "@type": "ContactPoint",
        "contactType": "customer service",
        "email": "carlos@rastrexando.eu"
      },
      "sameAs": ["https://www.facebook.com/rastrexando/"]
    }
    </script>
  </head>
  <body class="relative">
    {{ content | safe }}
  </body>
</html>
