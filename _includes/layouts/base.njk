---
title: Rastrexando
layout: skeleton
---

<div id="layout-base" hx-indicator="#rastrexando-logo img">
  <div class="animated-bg-wrapper">
    <section class="animated-section">
      <header class="wrapper">
        <a
          id="rastrexando-logo"
          href="/"
          hx-get="/"
          hx-target="#main-container"
          hx-select="#main-container"
          hx-swap="outerHTML"
          hx-push-url="true"
        >
          <img class="image" src="/recursos/rastrexando-simbolo.png" alt="Curuxa de Rastrexando" />
          <span class="title">Rastrexando</span>
        </a>
      </header>
      <div class='air air1'></div>
      <div class='air air2'></div>
      <div class='air air3'></div>
      <div class='air air4'></div>
    </section>
  </div>
  <main id="main-container">
    <div class="page-center-content">
      <div class="page-content">
        {{ content | safe }}
      </div>
    </div>
  </main>
  <footer id="main-footer">
    <div class="wrapper">
      <a
        class="footer-home"
        href="/"
        hx-get="/"
        hx-target="#main-container"
        hx-select="#main-container"
        hx-swap="outerHTML"
        hx-push-url="true"
      ><i class="fi-home"></i> Inicio</a>
      <nav class="footer-nav">
        <a
          href="/axuda/"
          hx-get="/axuda/"
          hx-target="#main-container"
          hx-select="#main-container"
          hx-swap="outerHTML"
          hx-push-url="true"
        ><i class="fi-info"></i> Axuda</a>
        <span class="footer-sep">·</span>
        <a href="https://www.facebook.com/rastrexando" target="_blank" rel="noopener noreferrer">
          <i class="fi-social-facebook"></i> Facebook
        </a>
        <span class="footer-sep">·</span>
        <a href="mailto:carlos@rastrexando.eu">
          <i class="fi-mail"></i> Contacto
        </a>
      </nav>
    </div>
  </footer>
</div>
