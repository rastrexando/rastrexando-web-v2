---
layout: base
title: Calendarios — Rastrexando
---

<nav class="breadcrumbs">
  <ul>
    <li>{% renderHTMXLink "/", "Inicio", "link" %}</li>
    <li class="breadcrumb-sep">›</li>
    <li>Calendarios</li>
  </ul>
</nav>

<div class="page page-calendarios">
  <header class="page-header">
    <h1><i class="fi-calendar is-light-blue"></i> Calendarios</h1>
  </header>
  <section class="year-grid">
    {% for year in years | reverse %}
      <a
        class="year-card{% if loop.first %} year-card--current{% endif %}"
        href="/calendarios/{{ year.name }}/"
        hx-get="/calendarios/{{ year.name }}/"
        hx-target="#main-container"
        hx-select="#main-container"
        hx-swap="outerHTML"
        hx-push-url="true"
        title="Calendario {{ year.name }}"
      >
        <span class="year-number">{{ year.name }}</span>
        <span class="year-count">
          {{ collections[year.name].length }}
          {% if collections[year.name].length == 1 %}evento{% else %}eventos{% endif %}
        </span>
      </a>
    {% endfor %}
  </section>
</div>
