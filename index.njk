---
layout: base
title: Inicio - Rastrexando
eleventyImport:
  data ["years"]
pagination:
  data: collections.featured
  size: 10
  reverse: true
  alias: posts
---


<div class="page page-index">
  {% if pagination.items.length > 0 %}
  <header class="page-header">
    <h1><i class="fi-star is-light-blue"></i> Destacados</h1>
  </header>
  <section>
    {% for post in pagination.items %}
      {% renderPost post %}
    {% endfor %}

    {% if pagination.pages.length > 1 %}
      <ul class="pagination">
        <li>Máis:</li>
        {%- for pageEntry in pagination.pages %}
          {% if page.url == pagination.hrefs[loop.index0] %}
            <li>{{ loop.index }}</li>
          {% else %}
            <li>
              <a href="{{ pagination.hrefs[ loop.index0 ] }}" {% if page.url == pagination.hrefs[ loop.index0 ] %} aria-current="page" {% endif %}>{{ loop.index }}</a>
            </li>
          {% endif %}
        {%- endfor %}
      </ul>
    {% endif %}
  </section>

  <div class="section-divider"></div>
  {% endif %}

  <section class="year-covers-section">
    <div class="year-covers-grid">
      {% for item in collections.yearCovers | reverse %}
      <a
        class="year-cover-item{% if not item.image %} no-image{% endif %}"
        href="{{ item.url }}"
        hx-get="{{ item.url }}"
        hx-target="#main-container"
        hx-select="#main-container"
        hx-swap="outerHTML"
        hx-push-url="true"
        {% if item.image %}style="--cover-img: url('/recursos/imaxes/{{ item.image }}')"{% endif %}
      >
        <span class="year-cover-label">{{ item.year }}</span>
      </a>
      {% endfor %}
    </div>
  </section>

</div>


